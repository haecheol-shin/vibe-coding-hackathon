# Azure / 앱 설정 (대회 전에 팀과 값 채우기)
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_LOCATION=koreacentral

# GitHub Copilot SDK
# 실제 값은 .env 또는 Azure App Service 앱 설정에만 넣고 커밋하지 않습니다.
COPILOT_GITHUB_TOKEN=
COPILOT_MODEL=gpt-4.1
COPILOT_REQUEST_TIMEOUT_SECONDS=90

# GitHub OAuth (Azure/공용 배포용)
# 로컬 개발에서는 gh auth login이 되어 있으면 로그인 버튼이 이 값 없이도 동작합니다.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/auth/github/callback

# Vue 프런트엔드 개발 서버 허용 origin
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
