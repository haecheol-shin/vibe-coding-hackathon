# Azure / 앱 설정 (대회 전에 팀과 값 채우기)
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_LOCATION=koreacentral

# GitHub Copilot SDK
# 실제 값은 .env 또는 Azure App Service 앱 설정에만 넣고 커밋하지 않습니다.
COPILOT_GITHUB_TOKEN=
COPILOT_MODEL=gpt-5
COPILOT_REQUEST_TIMEOUT_SECONDS=90

# Vue 프런트엔드 개발 서버 허용 origin
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
